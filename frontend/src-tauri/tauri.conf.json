{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sonix",
  "version": "0.1.0",
  "identifier": "com.voice.sonix",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Voice Workflow Assistant",
        "url": "http://localhost:5173"
      },
      {
        "label": "assistant",
        "url": "assistant.html",
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "fullscreen": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}